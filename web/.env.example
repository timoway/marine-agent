# Copy to .env for local dev
VITE_MAPBOX_TOKEN=pk.your_mapbox_token
# Restrict this token in Mapbox dashboard (URL allowlist):
#   https://marine-agent.vercel.app/*
#   https://*.vercel.app/*
#   http://localhost:5173/*
# Scopes: styles:read, fonts:read, tiles:read only. Rotate if ever committed/shared.
VITE_API_BASE=http://localhost:8000/api

# Production (Vercel): leave VITE_API_BASE unset — app uses /api proxy in vercel.json
# After Render deploy, confirm marine-agent.onrender.com matches vercel.json rewrite